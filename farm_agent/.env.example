# OpenAI（テンプレ追記の拡張・--llm-agent）。このファイルを .env にコピーして値を入れてください。
# キーは https://platform.openai.com/api-keys で発行（.env.example に本番キーを書かないこと）。
OPENAI_API_KEY=

# Chat Completions のモデル ID（省略時 gpt-4o-mini）。一覧: https://platform.openai.com/docs/models
# FARM_AGENT_OPENAI_MODEL=gpt-4o-mini

# 自律エージェント（ツール呼び出し）: python -m farm_agent.cli "場所" 作物 --llm-agent
# FARM_AGENT_AGENT_MAX_STEPS=14
# --llm-agent: モデルに明示指示で fetch_ndvi のあと JAXA を必ず1回呼ぶ
# FARM_AGENT_LLM_DEMO_JAXA=1
# --llm-agent: 最初の fetch_ndvi だけシミュレーション失敗（代替ツール選択の動作確認用）
# FARM_AGENT_LLM_DEMO_FORCE_NDVI_FAIL=1

# Required for Earth Engine after OAuth: your Google Cloud project id linked to EE
# (same as in https://code.earthengine.google.com/ → top bar / settings)
# EARTHENGINE_PROJECT=my-ee-project-id

# Sentinel-2 が弱いとき JAXA（GSMaP 降水・AMSR2 土壌水分）を取りに行く（要 jaxa-earth）
# FARM_AGENT_USE_JAXA=1
# Sentinel に依存せず JAXA のみ試す: python -m farm_agent.cli "lat,lon" 作物 --jaxa
# FARM_AGENT_JAXA_DAYS=30
# FARM_AGENT_JAXA_PPU=8
# HTML 用ラスタ PNG サムネ（matplotlib。JAXA Earth API に公式サムネ URL は無いため自前生成）
# FARM_AGENT_JAXA_THUMB=1
# 集計矩形の半幅（度）。狭すぎると JAXA API が失敗しやすい（既定 0.25 ≒ 辺 0.5°）
# FARM_AGENT_JAXA_BBOX_HALF_DEG=0.25
# SSL エラー時のみ: FARM_AGENT_JAXA_SSL_VERIFY=0
